# Benchmark outputs (manifests and schemas are tracked)
benchmarks/results/*
!benchmarks/results/.gitkeep
!benchmarks/results/README.md

# External benchmark dependencies (clone per benchmarks/soccernet-gsr/README.md)
benchmarks/vendor/

# Datasets, model weights, large media
data/
*.pkl
*.pklz
*.pt
*.pth
*.onnx
*.mp4
*.mkv
*.avi
*.mov

# Experiment inputs (images stay local; track empty dirs via .gitkeep)
sportify-game-reconstruction/experiments/easyocr/images/**
!sportify-game-reconstruction/experiments/easyocr/images/**/
!sportify-game-reconstruction/experiments/easyocr/images/**/.gitkeep

