# Copy to sportify-env.local.sh and edit (sportify-env.local.sh is gitignored).
#
#   cp scripts/sportify-env.local.sh.example scripts/sportify-env.local.sh

# Machine-specific data root (VPS, laptop, cloud workspace, etc.)
# export SPORTIFY_DATA_ROOT="/workspace"
# export SPORTIFY_DATA_ROOT="/mnt/data/sportify"

# Keep /root/data/sportify on a cloud box that has /workspace (not recommended):
# export SPORTIFY_DATA_ROOT="/root/data/sportify"
# export SPORTIFY_DATA_ROOT_FORCE=1

# Password from SoccerNet NDA email (if download asks for it)
# export SOCCERNET_PWD="your-password-here"
